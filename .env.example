# =============================================================================
# VWAP Pullback Scanner — Environment Variables
# Copy this file to .env, fill in real values, and source it before running.
# NEVER commit .env to version control.
# On Railway: set these in the Railway dashboard under Variables.
# =============================================================================

# --- Required: Massive Market Data ---
MASSIVE_API_KEY=your_massive_market_data_api_key_here
MASSIVE_BASE_URL=https://api.massivemarketdata.com   # or your custom base URL

# --- Required: Telegram Bot ---
# Create a bot via @BotFather on Telegram, then copy the token below.
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your personal chat ID — send /start to @userinfobot to get it.
TELEGRAM_CHAT_ID=987654321

# --- Optional: Strategy overrides (defaults shown) ---
# ATR_TOUCH_MULTIPLIER=0.5
# ATR_PERIOD=14
# RSI_PERIOD=14
# RSI_MIN=40
# RSI_MAX=60
# VOLUME_AVG_PERIOD=20
# MIN_BARS_ABOVE_VWAP=3
# MAX_VWAP_TOUCHES=2
# VIX_MAX=25.0
# TP1_R=1.5
# TP2_R=3.0
# SL_ATR_MULTIPLIER=1.5
# GRIND_ZONE_PCT=0.001
# GRIND_MAX_BARS=4

# --- Optional: Polling intervals (seconds) ---
# POLL_INTERVAL_SEC=60
# SPY_REFRESH_SEC=300
# VIX_REFRESH_SEC=900
# TIER2_POLL_SEC=15
# REQUEST_DELAY_SEC=0.2

# --- Optional: Paths ---
# WATCHLIST_PATH=watchlist.txt
